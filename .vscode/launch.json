{
    "version": "0.2.0",
    "configurations": [
      {
        "type": "node",
        "request": "launch",
        "name": "Debug TS (ts-node)",
        "runtimeArgs": [
          "-r",
          "ts-node/register"
        ],
        "args": [
          "${workspaceFolder}/src/server.ts"
        ],
        "skipFiles": [
          "<node_internals>/**"
        ],
        "env": {
          "NODE_ENV": "development"
        }
      }
    ]
  }